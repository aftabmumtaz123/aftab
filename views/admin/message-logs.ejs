<div class="container-fluid py-6 px-4 md:px-8 max-w-7xl mx-auto">

    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8">
        <div>
            <h1 class="text-3xl font-bold text-gray-900 tracking-tight">Message Logs & Bulk</h1>
            <p class="text-gray-500 mt-1 font-medium">Track your automated communications</p>
        </div>
        <div class="mt-4 md:mt-0 flex flex-col md:flex-row items-center gap-3">
            <button onclick="document.getElementById('bulkModal').classList.remove('hidden')" class="inline-flex items-center px-5 py-2.5 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold rounded-xl shadow-sm hover:shadow transition-all duration-200">
                <i class="fas fa-bullhorn mr-2"></i> Blast Announcement
            </button>
        </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center transition-all">
            <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 mr-4">
                <i class="fas fa-paper-plane text-xl"></i>
            </div>
            <div>
                <p class="text-sm font-medium text-gray-500">Messages Sent</p>
                <h3 class="text-2xl font-bold text-gray-900"><%= stats.totalSent %></h3>
            </div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center transition-all">
            <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center text-red-600 mr-4">
                <i class="fas fa-exclamation-triangle text-xl"></i>
            </div>
            <div>
                <p class="text-sm font-medium text-gray-500">Delivery Failures</p>
                <h3 class="text-2xl font-bold text-gray-900"><%= stats.totalFailed %></h3>
            </div>
        </div>
    </div>

    <!-- Logs Table -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="p-5 border-b border-gray-100 bg-gray-50/50 flex flex-col sm:flex-row justify-between items-center">
            <h3 class="font-bold text-gray-800">Recent Outbound Log</h3>
        </div>

        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase">Timestamp</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase">Recipient</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase">Message Snippet</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase">Type</th>
                        <th class="px-6 py-4 text-right text-xs font-semibold text-gray-500 uppercase">Status</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-100">
                    <% if (logs.length > 0) { %>
                        <% logs.forEach(log => { %>
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    <%= new Date(log.createdAt).toLocaleString([], { dateStyle: 'short', timeStyle: 'short' }) %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm font-bold text-gray-900"><%= log.person ? log.person.name : 'Unknown' %></div>
                                    <div class="text-xs text-gray-500">To: +<%= log.toPhone.replace('@c.us', '') %></div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="text-sm text-gray-700 max-w-xs truncate" title="<%= log.text %>">
                                        <%= log.text.substring(0, 50) %><%= log.text.length > 50 ? '...' : '' %>
                                    </div>
                                    <% if(log.errorMessage) { %>
                                        <div class="text-xs text-red-500 mt-1 truncate max-w-xs"><%= log.errorMessage %></div>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-2 py-1 text-xs font-medium rounded-md bg-gray-100 text-gray-600 border border-gray-200"><%= log.type %></span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right">
                                    <% if(log.status === 'Sent') { %>
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                            <i class="fas fa-check mr-1.5"></i> Sent
                                        </span>
                                    <% } else { %>
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                            <i class="fas fa-times mr-1.5"></i> Failed
                                        </span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="px-6 py-12 text-center text-gray-500">
                                No messages have been logged yet.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Bulk Blast Modal -->
<div id="bulkModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-gray-900/50 backdrop-blur-sm">
    <div class="bg-white rounded-2xl shadow-xl max-w-lg w-full mx-4 overflow-hidden">
        <form action="/admin/whatsapp/bulk" method="POST">
            <div class="bg-green-600 p-5 p-6 flex justify-between items-center">
                <h3 class="text-white font-bold text-lg"><i class="fas fa-bullhorn mr-2"></i> Blast Announcement</h3>
                <button type="button" onclick="document.getElementById('bulkModal').classList.add('hidden')" class="text-green-200 hover:text-white">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>
            <div class="p-6">
                <p class="text-sm text-gray-500 mb-4">Type a message below to broadcast to EVERY person in your database who has a registered phone number. Supports <code class="bg-gray-100 text-pink-500 px-1 rounded">{{name}}</code> variables.</p>
                
                <label class="block text-sm font-semibold text-gray-700 mb-2">Message Body</label>
                <textarea name="messageText" rows="6" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-green-500 text-gray-700 resize-none transition-all" placeholder="Hello {{name}}, we have an exciting announcement..." required></textarea>
                
            </div>
            <div class="p-5 border-t border-gray-100 bg-gray-50 flex justify-end gap-3 rounded-b-2xl">
                <button type="button" onclick="document.getElementById('bulkModal').classList.add('hidden')" class="px-5 py-2.5 text-gray-600 font-medium hover:bg-gray-200 rounded-xl transition-all">Cancel</button>
                <button type="submit" onclick="this.innerHTML='<i class=\'fas fa-circle-notch fa-spin mr-2\'></i> Starting...'; this.classList.add('opacity-75');" class="px-6 py-2.5 bg-green-600 hover:bg-green-700 text-white font-bold rounded-xl shadow-lg shadow-green-600/30 transition-all flex items-center">
                    <i class="fas fa-paper-plane mr-2"></i> Publish
                </button>
            </div>
        </form>
    </div>
</div>
